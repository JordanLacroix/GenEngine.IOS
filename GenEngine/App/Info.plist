<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>Microsoft Entra ID</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>genengine</string>
			</array>
		</dict>
	</array>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<!-- Nom affiché sur l'écran d'accueil. Il porte le nom de la *configuration* livrée,
	     pas celui du moteur : un joueur du Diapason ne doit pas lancer « GenEngine ».
	     C'est un réglage d'industrialisation, à changer par instance client au même titre
	     que l'icône. L'identité de code — nom de cible, PRODUCT_NAME, bundle identifier —
	     reste « GenEngine » et ne bouge pas. -->
	<!-- Le binaire reste le moteur : « Le Diapason » est une configuration, servie
	     à l'exécution par GET /client-bootstrap et affichée dans toute l'interface.
	     Le nom du bundle est figé à la compilation et ne peut pas en venir ; une
	     instance client le redéfinit en recompilant avec sa propre marque. -->
	<key>CFBundleDisplayName</key>
	<string>GenEngine</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>NSLocalNetworkUsageDescription</key>
	<string>GenEngine can connect to a development server on your local network.</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
</dict>
</plist>
